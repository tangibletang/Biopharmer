OPENAI_API_KEY=sk-...
# Optional: daily prices use Alpha Vantage first; omit to use Yahoo Finance only.
# https://www.alphavantage.co/support/#api-key — free tier is rate-limited.
ALPHA_VANTAGE_API_KEY=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
# Direct psycopg2 connection used by the API layer for pgvector raw SQL
# Format: postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
